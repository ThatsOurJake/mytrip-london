# Optional API keys
# If these are not provided, the app falls back to heuristic routing.

ORS_API_KEY=
TFL_APP_KEY=

# Optional server-side cache TTL for /api/route-segment responses in milliseconds.
# Defaults to 1800000 (30 minutes).
ROUTE_SEGMENT_CACHE_TTL_MS=1800000

# Optional provider debug logging toggle.
ROUTING_DEBUG=true
